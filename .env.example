# Backend ML Server Configuration
# Live Render deployment (CyberSentinel ML API)
NEXT_PUBLIC_BACKEND_URL=https://cybersentinel-ml.onrender.com
BACKEND_URL=https://cybersentinel-ml.onrender.com

# For local development, use:
# NEXT_PUBLIC_BACKEND_URL=http://localhost:10000
# BACKEND_URL=http://localhost:10000

# Backend API Key (if authentication is required)
BACKEND_API_KEY=

# API Configuration
NEXT_PUBLIC_API_URL=/api

# Environment
NODE_ENV=production
